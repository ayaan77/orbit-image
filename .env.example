# Required
OPENAI_API_KEY=sk-...
API_SECRET_KEY=orbit-img-...

# Optional (defaults shown)
CORTEX_BASE_URL=https://cortex.apexure.com/api/mcp
DEFAULT_BRAND=apexure
CACHE_TTL_SECONDS=3600
RATE_LIMIT_PER_MINUTE=60

# MCP image delivery (required for output_format: "url")
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Multi-tenant API keys (optional — falls back to master-key-only mode)
KV_REST_API_URL=https://your-redis.upstash.io
KV_REST_API_TOKEN=AX...

# Usage tracking (optional — skipped if not set)
POSTGRES_URL=postgresql://user:pass@host/dbname

# Webhook signing secret (optional — required for async webhook delivery)
WEBHOOK_SECRET=your-webhook-secret-min-16-chars

# Mock provider for testing (no OpenAI costs)
# USE_MOCK_PROVIDER=true
